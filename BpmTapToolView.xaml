<UserControl x:Class="BpmTapTool.BpmTapToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="550" Width="800">
	<TabControl>
		<!-- 測定タブ -->
		<TabItem Header="BPM測定">
			<Grid Background="#F0F0F0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Margin="10" HorizontalAlignment="Center">
					<TextBlock Text="{Binding TapCountDisplay}" FontSize="16" FontWeight="Bold" Foreground="#555555" HorizontalAlignment="Center"/>
					<TextBlock Text="{Binding InstantBpmDisplay}" FontSize="14" Foreground="#333333" Margin="0,5,0,0" HorizontalAlignment="Center"/>
					<TextBlock Text="{Binding AverageBpmDisplay}" FontSize="14" Foreground="#333333" HorizontalAlignment="Center"/>
				</StackPanel>

				<Button Grid.Row="2"
                        Command="{Binding TapCommand}"
                        Background="#FF6200EE"
                        Foreground="White"
                        FontSize="24"
                        FontWeight="Bold"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="300"
                        Height="300"
                        Margin="20">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border Background="{TemplateBinding Background}"
                                    CornerRadius="150"
                                    BorderBrush="#FF3700B3"
                                    BorderThickness="3">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</Border>
						</ControlTemplate>
					</Button.Template>
					<TextBlock Text="{Binding TapButtonText}" FontSize="28" TextWrapping="Wrap" TextAlignment="Center"/>
				</Button>

				<Button Grid.Row="2"
                        Command="{Binding ResetCommand}"
                        Width="60" Height="60"
                        FontSize="20"
                        Margin="15"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right"
                        ToolTip="測定をリセットします"
                        Background="#FF03DAC6"
                        Foreground="White">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border Background="{TemplateBinding Background}" CornerRadius="30">
								<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</Border>
						</ControlTemplate>
					</Button.Template>
					↺
				</Button>
			</Grid>
		</TabItem>

		<!-- 履歴タブ -->
		<TabItem Header="履歴">
			<Grid Margin="10">
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<ListView Grid.Row="0" ItemsSource="{Binding History}"
                          SelectedItem="{Binding SelectedHistoryItem, Mode=TwoWay}"
                          Margin="0,0,0,10">
					<ListView.View>
						<GridView>
							<GridViewColumn Header="日時" DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="80"/>
							<GridViewColumn Header="平均BPM" DisplayMemberBinding="{Binding AverageBpm}" Width="80"/>
							<GridViewColumn Header="瞬間BPM" DisplayMemberBinding="{Binding InstantBpm}" Width="80"/>
							<GridViewColumn Header="タップ数" DisplayMemberBinding="{Binding TapCount}" Width="70"/>
							<GridViewColumn Header="名前" DisplayMemberBinding="{Binding Name}" Width="120"/>
							<GridViewColumn Header="備考" DisplayMemberBinding="{Binding Note}" Width="200"/>
							<GridViewColumn Header="ピン" Width="50">
								<GridViewColumn.CellTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding IsPinned}" HorizontalAlignment="Center"/>
									</DataTemplate>
								</GridViewColumn.CellTemplate>
							</GridViewColumn>
						</GridView>
					</ListView.View>
				</ListView>

				<StackPanel Grid.Row="1" Margin="0,5" Orientation="Horizontal">
					<TextBlock Text="名前:" VerticalAlignment="Center" Margin="0,0,5,0"/>
					<TextBox Text="{Binding SelectedHistoryItem.Name, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="0,0,15,0"/>
					<TextBlock Text="備考:" VerticalAlignment="Center" Margin="0,0,5,0"/>
					<TextBox Text="{Binding SelectedHistoryItem.Note, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,15,0"/>
				</StackPanel>

				<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
					<Button Command="{Binding PinHistoryCommand}" Content="ピン留め切り替え" Width="120" Margin="5"/>
					<Button Command="{Binding DeleteHistoryCommand}" Content="削除" Width="80" Margin="5" Background="#FF4444" Foreground="White"/>
				</StackPanel>
			</Grid>
		</TabItem>
	</TabControl>
</UserControl>